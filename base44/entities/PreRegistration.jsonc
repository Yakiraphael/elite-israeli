        "\u05de\u05e0\u05d4\u05dc \u05de\u05e7\u05e6\u05d5\u05e2\u05d9",
        "\u05d0\u05d7\u05e8"
      ]
    },
    "club_name": {
      "type": "string",
      "title": "\u05e9\u05dd \u05de\u05d5\u05e2\u05d3\u05d5\u05df (\u05d0\u05dd \u05e8\u05dc\u05d5\u05d5\u05e0\u05d8\u05d9)"
    },
