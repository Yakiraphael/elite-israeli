      "title": "\u05d8\u05dc\u05e4\u05d5\u05df"
    },
    "role_interest": {
      "type": "string",
      "title": "\u05ea\u05d7\u05d5\u05dd \u05e2\u05e0\u05d9\u05d9\u05df",
      "enum": [
        "\u05e9\u05d7\u05e7\u05df",
