    "guardian_id": {
      "type": "string",
      "title": "\u05ea\u05e2\u05d5\u05d3\u05ea \u05d6\u05d4\u05d5\u05ea \u05e9\u05dc \u05d4\u05d4\u05d5\u05e8\u05d4",
      "description": "\u05d7\u05d5\u05d1\u05d4 \u05dc\u05e7\u05d8\u05d9\u05e0\u05d9\u05dd \u2014 \u05e8\u05d2\u05d5\u05dc\u05e6\u05d9\u05d9\u05ea \u05d4\u05ea\u05d0\u05d7\u05d3\u05d5\u05ea"
    },
    "id_document_url": {
      "type": "string",
      "title": "\u05e6\u05d9\u05dc\u05d5\u05dd \u05ea\u05e2\u05d5\u05d3\u05ea \u05d6\u05d4\u05d5\u05ea"
    },
    "id_suffix_url": {
      "type": "string",
      "title": "\u05e1\u05e4\u05d7 \u05ea\u05e2\u05d5\u05d3\u05ea \u05d6\u05d4\u05d5\u05ea \u05e4\u05ea\u05d5\u05d7",
      "description": "\u05d7\u05d5\u05d1\u05d4 \u05dc\u05e7\u05d8\u05d9\u05e0\u05d9\u05dd \u2014 \u05d4\u05d5\u05db\u05d7\u05ea \u05e9\u05d9\u05d5\u05da \u05d4\u05d5\u05e8\u05d4-\u05e7\u05d8\u05d9\u05df"
    },
    "medical_certificate_url": {
      "type": "string",
      "title": "\u05d0\u05d9\u05e9\u05d5\u05e8 \u05d1\u05d3\u05d9\u05e7\u05d4 \u05e8\u05e4\u05d5\u05d0\u05d9\u05ea \u05d1\u05ea\u05d5\u05e7\u05e3"
    },
    "medical_expiry_date": {
      "type": "string",
      "format": "date",
      "title": "\u05ea\u05d0\u05e8\u05d9\u05da \u05e4\u05e7\u05d9\u05e2\u05ea \u05ea\u05d5\u05e7\u05e3 \u05e8\u05e4\u05d5\u05d0\u05d9",
      "description": "\u05d4\u05de\u05e2\u05e8\u05db\u05ea \u05ea\u05ea\u05e8\u05d9\u05e2 30 \u05d9\u05d5\u05dd \u05dc\u05e4\u05e0\u05d9 \u05e4\u05e7\u05d9\u05e2\u05d4"
    },
    "bank_token": {
      "type": "string",
      "title": "Token \u05d0\u05de\u05e6\u05e2\u05d9 \u05ea\u05e9\u05dc\u05d5\u05dd",
      "description": "\u05dc\u05d1\u05d5\u05d2\u05e8\u05d9\u05dd \u05d1\u05dc\u05d1\u05d3 \u2014 \u05e0\u05e9\u05de\u05e8 \u05de\u05d0\u05d5\u05d1\u05d8\u05d7 \u05d0\u05e6\u05dc \u05d7\u05d1\u05e8\u05ea \u05d4\u05e1\u05dc\u05d9\u05e7\u05d4"
    },
    "status": {
      "type": "string",
      "title": "\u05e1\u05d8\u05d8\u05d5\u05e1 \u05e8\u05d9\u05e9\u05d5\u05dd",
      "enum": [
        "\u05de\u05ea\u05d9\u05df",
        "\u05de\u05d0\u05d5\u05e9\u05e8",
        "\u05e4\u05e2\u05d9\u05dc",
        "\u05d4\u05d5\u05e2\u05d1\u05e8",
        "IFA Ready"
      ],
      "default": "\u05de\u05ea\u05d9\u05df"
    },
    "is_adult": {
      "type": "boolean",
      "title": "\u05e9\u05d7\u05e7\u05df \u05d1\u05d5\u05d2\u05e8 (18+)",
      "default": false,
      "description": "\u05de\u05d7\u05d5\u05e9\u05d1 \u05d0\u05d5\u05d8\u05d5\u05de\u05d8\u05d9\u05ea \u05de\u05ea\u05d0\u05e8\u05d9\u05da \u05dc\u05d9\u05d3\u05d4. \u05d0\u05dd true \u2014 \u05d6\u05e8\u05d9\u05de\u05ea \u05d1\u05d5\u05d2\u05e8\u05d9\u05dd. \u05d0\u05dd false \u2014 \u05d6\u05e8\u05d9\u05de\u05ea \u05e0\u05d5\u05e2\u05e8 \u05e2\u05dd \u05d7\u05d5\u05d1\u05ea \u05d0\u05e4\u05d5\u05d8\u05e8\u05d5\u05e4\u05d5\u05e1."
    },
    "ifa_ready": {
      "type": "boolean",
      "title": "IFA Ready",
      "default": false,
      "description": "\u05db\u05dc \u05d4\u05de\u05e1\u05de\u05db\u05d9\u05dd \u05d4\u05d5\u05e2\u05dc\u05d5, \u05ea\u05d9\u05e7 \u05e8\u05d9\u05e9\u05d5\u05dd \u05de\u05d5\u05db\u05df, \u05d4\u05de\u05e2\u05e8\u05db\u05ea \u05e0\u05e7\u05d9\u05d9\u05d4 \u05de\u05d4\u05e4\u05e8\u05e2\u05d5\u05ea"
    },
    "legal_terms_accepted": {
      "type": "object",
      "title": "\u05d0\u05d9\u05e9\u05d5\u05e8 \u05ea\u05e0\u05d0\u05d9\u05dd \u05de\u05e9\u05e4\u05d8\u05d9\u05d9\u05dd",
      "properties": {
        "platform_terms": {
          "type": "boolean",
          "title": "\u05d0\u05d9\u05e9\u05d5\u05e8 \u05ea\u05e7\u05e0\u05d5\u05df \u05d4\u05e4\u05dc\u05d8\u05e4\u05d5\u05e8\u05de\u05d4"
        },
        "digital_power_of_attorney": {
          "type": "boolean",
          "title": "\u05d9\u05d9\u05e4\u05d5\u05d9 \u05db\u05d5\u05d7 \u05d1\u05d9\u05e8\u05d5\u05e7\u05e8\u05d8\u05d9 \u05d3\u05d9\u05d2\u05d9\u05d8\u05dc\u05d9"
        },
        "medical_waiver": {
          "type": "boolean",
          "title": "\u05d5\u05d9\u05ea\u05d5\u05e8 \u05e1\u05d5\u05d3\u05d9\u05d5\u05ea \u05e8\u05e4\u05d5\u05d0\u05d9\u05ea \u05de\u05d5\u05d2\u05d1\u05dc"
        },
        "digital_representation": {
          "type": "boolean",
          "title": "\u05d1\u05dc\u05e2\u05d3\u05d9\u05d5\u05ea \u05d9\u05d9\u05e6\u05d5\u05d2 \u05d3\u05d9\u05d2\u05d9\u05d8\u05dc\u05d9 (5%)"
        },
        "payment_pre_auth": {
          "type": "boolean",
          "title": "\u05d0\u05d9\u05e9\u05d5\u05e8 \u05e1\u05dc\u05d9\u05e7\u05d4 \u05de\u05e8\u05d0\u05e9"
        }
      }
    },
    "digital_signature": {
      "type": "string",
      "title": "\u05d7\u05ea\u05d9\u05de\u05d4 \u05d3\u05d9\u05d2\u05d9\u05d8\u05dc\u05d9\u05ea"
    },
    "is_free_agent": {
      "type": "boolean",
      "title": "\u05e9\u05d7\u05e7\u05df \u05d7\u05d5\u05e4\u05e9\u05d9",
      "default": false
    },
    "ifa_registration_status": {
      "type": "string",
      "title": "\u05e1\u05d8\u05d8\u05d5\u05e1 \u05e8\u05d9\u05e9\u05d5\u05dd \u05d1\u05d4\u05ea\u05d0\u05d7\u05d3\u05d5\u05ea",
      "enum": [
        "Under Contract",
