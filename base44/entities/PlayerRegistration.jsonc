    },
    "guardian_name": {
      "type": "string",
      "title": "\u05e9\u05dd \u05de\u05dc\u05d0 \u05e9\u05dc \u05d4\u05d4\u05d5\u05e8\u05d4/\u05d0\u05e4\u05d5\u05d8\u05e8\u05d5\u05e4\u05d5\u05e1",
